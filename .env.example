# =========================
# JupyterHub ↔ Keycloak OIDC
# =========================

# Keycloak realm name
KC_REALM=<keycloak realm name>

# Public Keycloak base URL (what the browser uses)
KC_BASE_URL=<keycloak base url>

# Keycloak client (the one you created for JupyterHub)
KC_CLIENT_ID=jupyterhub
KC_CLIENT_SECRET=<your keycloak client secret>

# =========================
# DockerSpawner
# =========================

# Notebook image for single-user servers
DOCKER_NOTEBOOK_IMAGE=energyguard-singleuser:latest

# Docker network that JupyterHub + user servers share
# Must exist (external network in your docker-compose)
DOCKER_NETWORK_NAME=nginxproxy_energyguard_net
MLFLOW_TRACKING_URI=<your mlflow tracking uri>
JUPYTERHUB_CRYPT_KEY=<your jupyterhub crypt key>
JH_COOKIE_SAMESITE=none
JH_COOKIE_SECURE=true

# =========================
# Data Management Server
# =========================
# Host path that is bind-mounted into this JupyterHub container as
# /jupyterhub_data.  Used by pre_spawn_hook to create per-user directories
# before DockerSpawner bind-mounts them into singleuser containers.
JUPYTERHUB_DATA_HOST_PATH=<your host path for jupyterhub data>
